# ==========================================
# 私募基金拓客辅助系统 — 环境配置
# ==========================================
# 使用方法：
#   1. 复制本文件为 .env
#   2. 修改其中的配置值（特别是密码和密钥）
#   3. .env 已加入 .gitignore，不会提交到版本控制
# ==========================================

# === 数据库配置 — ts_quant_db（只读，私募数据来源） ===
TS_QUANT_DB_HOST=localhost
TS_QUANT_DB_PORT=5432
TS_QUANT_DB_NAME=ts_quant_db
TS_QUANT_DB_USER=db_query_user
TS_QUANT_DB_PASSWORD=123456789

# === 数据库配置 — fund_map_db（读写，业务数据） ===
FUND_MAP_DB_HOST=localhost
FUND_MAP_DB_PORT=5432
FUND_MAP_DB_NAME=fund_map_db
FUND_MAP_DB_USER=fund_map_user
FUND_MAP_DB_PASSWORD=123456789

# === JWT 认证 ===
JWT_SECRET=private-fund-map-jwt-secret-key-2025
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# === API 地址（前端连接后端用） ===
API_BASE_URL=http://localhost:8100
